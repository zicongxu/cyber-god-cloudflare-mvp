{
  "name": "cyber-god-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test:stepfun-prompts": "node scripts/test-stepfun-prompts.mjs",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply cyber_god_mvp --local",
    "db:migrate:remote": "wrangler d1 migrations apply cyber_god_mvp --remote",
    "god": "node bin/cyber-god.mjs",
    "god:enter": "node bin/cyber-god.mjs enter"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "^5.8.3",
    "wrangler": "latest"
  },
  "bin": {
    "cyber-god": "bin/cyber-god.mjs"
  }
}
